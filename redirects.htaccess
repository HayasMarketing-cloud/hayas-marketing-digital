# ========================================
# REDIRECCIONES DE CONTENIDO ELIMINADO
# ========================================
# URLs de servicios Kit Consulting que fueron eliminados

<IfModule mod_rewrite.c>
    # Redirigir URLs eliminadas permanentemente a página personalizada
    RewriteCond %{REQUEST_URI} ^/es/servicio-de-asesoramiento-en-inteligencia-artificial-con-kit-consulting/?$ [OR]
    RewriteCond %{REQUEST_URI} ^/es/servicio-de-asesoramiento-en-analisis-de-datos-avanzado-con-kit-consulting/?$ [OR]
    RewriteCond %{REQUEST_URI} ^/es/servicio-de-asesoramiento-en-transformacion-digital-360-con-kit-consulting/?$ [OR]
    RewriteCond %{REQUEST_URI} ^/es/servicio-de-asesoramiento-en-ventas-digitales-con-kit-consulting/?$ [OR]
    RewriteCond %{REQUEST_URI} ^/es/servicio-de-asesoramiento-en-analisis-de-datos-basico-con-kit-consulting/?$ [OR]
    RewriteCond %{REQUEST_URI} ^/es/servicio-de-asesoramiento-en-ciberseguridad-con-kit-consulting/?$ [OR]
    RewriteCond %{REQUEST_URI} ^/es/kitconsulting/asesoramiento-en-inteligencia-artificial-aplicada-a-marketing-digital-con-kit-consulting/?$ [OR]
    RewriteCond %{REQUEST_URI} ^/es/kitconsulting/asesoramiento-estrategia-rendimiento-de-negocio-ia-kit-consulting/?$ [OR]
    RewriteCond %{REQUEST_URI} ^/es/kitconsulting/?$
    RewriteRule ^ /es/contenido-eliminado [R=301,L]
</IfModule>

# ========================================
# NOTA IMPORTANTE
# ========================================
# Redirecciones migradas desde WordPress/RankMath para mantener SEO.
# Todas las URLs críticas del blog y servicios han sido preservadas.
# Las redirecciones están organizadas por categorías para facilitar el mantenimiento.